{
  "tailwindCSS.experimental.configFile": "apps/monitor-web/tailwind.config.ts",
  "cSpell.words": [
    "jikwon",
    "junyeol",
    "Kakao",
    "neutural",
    "supabase",
    "VWORLD"
  ],
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "eslint.workingDirectories": [
    { "directory": "apps/monitor-web", "changeProcessCWD": true },
    { "directory": "apps/schedule", "changeProcessCWD": true }
  ],

  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ]
}
